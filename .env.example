OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# optional — tag-songs（离线歌曲标签）
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# LASTFM_API_KEY=

# optional
# NETEASE_API_BASE=http://127.0.0.1:3000
# LEARN_PORT=8787

# optional — 网易云登录 Cookie（解锁完整播放，避免 30 秒试听）
# 可只填 MUSIC_U 的值，或填完整 cookie 串；仅本机使用，勿提交
# NETEASE_COOKIE=MUSIC_U=你的_MUSIC_U
